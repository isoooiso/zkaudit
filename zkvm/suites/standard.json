{
  "tests": [
    {
      "id": 1,
      "setup": [{ "Deposit": { "user": 1, "amount": 100 } }],
      "action": { "Withdraw": { "user": 1, "amount": 40 } },
      "expect": "Ok",
      "post": [
        { "BalanceEq": { "user": 1, "expected": 60 } },
        "Conservation"
      ]
    },
    {
      "id": 2,
      "setup": [{ "Deposit": { "user": 1, "amount": 100 } }],
      "action": { "Withdraw": { "user": 1, "amount": 100 } },
      "expect": "Ok",
      "post": [
        { "BalanceEq": { "user": 1, "expected": 0 } },
        "Conservation"
      ]
    },
    {
      "id": 3,
      "setup": [
        { "Deposit": { "user": 1, "amount": 100 } },
        { "Deposit": { "user": 2, "amount": 100 } }
      ],
      "action": { "Withdraw": { "user": 1, "amount": 150 } },
      "expect": "ErrAny",
      "post": [
        { "BalanceEq": { "user": 2, "expected": 100 } },
        "Conservation"
      ]
    },
    {
      "id": 4,
      "setup": [{ "Deposit": { "user": 1, "amount": 100 } }],
      "action": { "Transfer": { "from": 1, "to": 1, "amount": 50 } },
      "expect": "Ok",
      "post": [
        { "BalanceEq": { "user": 1, "expected": 100 } },
        "Conservation"
      ]
    },
    {
      "id": 5,
      "setup": [
        { "Deposit": { "user": 1, "amount": 200 } },
        { "Transfer": { "from": 1, "to": 2, "amount": 100 } }
      ],
      "action": { "SweepFees": { "caller": 2 } },
      "expect": "ErrAny",
      "post": [{ "FeesEq": { "expected": 1 } }]
    },
    {
      "id": 6,
      "setup": [
        { "Deposit": { "user": 1, "amount": 200 } },
        { "Transfer": { "from": 1, "to": 2, "amount": 100 } }
      ],
      "action": { "SweepFees": { "caller": 0 } },
      "expect": "Ok",
      "post": [{ "FeesEq": { "expected": 0 } }, "Conservation"]
    },
    {
      "id": 7,
      "setup": [{ "Deposit": { "user": 1, "amount": 200 } }],
      "action": { "Transfer": { "from": 1, "to": 2, "amount": 100 } },
      "expect": "Ok",
      "post": [
        { "BalanceEq": { "user": 1, "expected": 100 } },
        { "BalanceEq": { "user": 2, "expected": 99 } },
        { "FeesEq": { "expected": 1 } },
        "Conservation"
      ]
    },
    {
      "id": 8,
      "setup": [
        { "Deposit": { "user": 1, "amount": 300 } },
        { "Deposit": { "user": 2, "amount": 50 } },
        { "Transfer": { "from": 1, "to": 2, "amount": 200 } }
      ],
      "action": { "Withdraw": { "user": 2, "amount": 100 } },
      "expect": "Ok",
      "post": ["Conservation"]
    },
    {
      "id": 9,
      "setup": [],
      "action": { "Withdraw": { "user": 3, "amount": 10 } },
      "expect": "ErrAny",
      "post": [{ "BalanceEq": { "user": 3, "expected": 0 } }]
    },
    {
      "id": 10,
      "setup": [{ "Deposit": { "user": 1, "amount": 100 } }],
      "action": { "Transfer": { "from": 1, "to": 2, "amount": 0 } },
      "expect": "ErrAny",
      "post": [{ "BalanceEq": { "user": 1, "expected": 100 } }]
    }
  ]
}
